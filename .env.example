# Authentication secret - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-secret
AUTH_SECRET=change-me-to-a-random-secret

# Base URL for NextAuth
NEXTAUTH_URL=http://localhost:3000

# The Odds API — get a free key at https://the-odds-api.com
# Free tier: 500 requests/month (~1 scan/day across all leagues)
ODDS_API_KEY=
